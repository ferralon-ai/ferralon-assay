#!/usr/bin/env bash
# The real local gate: refuse to push ANY commit whose author or committer
# is not the shared anonymous identity. Catches --author overrides, cherry-picks,
# merges and rebased-in foreign commits that pre-commit cannot see.
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$here/identity"
expected="$NAME <$EMAIL>"

z40=0000000000000000000000000000000000000000
bad=0

while read -r _local_ref local_sha _remote_ref remote_sha; do
  [ "$local_sha" = "$z40" ] && continue   # branch deletion

  if [ "$remote_sha" = "$z40" ]; then
    # New branch: check every commit not already on any remote-tracking branch.
    set -- "$local_sha" --not --remotes
  else
    set -- "$remote_sha..$local_sha"
  fi

  while read -r sha ident; do
    if [ "$ident" != "$expected" ]; then
      echo "pre-push: $sha has non-anonymous identity: $ident (expected: $expected)" >&2
      bad=1
    fi
  # one line per author and per committer for every commit in range
  done < <(git log --format='%H %an <%ae>%n%H %cn <%ce>' "$@" 2>/dev/null)
done

if [ "$bad" -ne 0 ]; then
  echo "" >&2
  echo "Push blocked. Rewrite the offending commits to the shared identity before pushing." >&2
  exit 1
fi
